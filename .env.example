# =============================================================================
# RAGQnASystem — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# =============================================================================

# --- Neo4j ---
NEO4J_URI=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=all-in-rag
NEO4J_DATABASE=neo4j

# --- Milvus / Zilliz Cloud ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_COLLECTION=medical_qa

# --- Embedding ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# --- Data paths ---
TOYHOM_DATASET_PATH=Chinese-medical-dialogue-data/Data_数据
USER_UPLOAD_CASE_PATH=user_uploads/cases

# --- Retrieval ---
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# --- LLM ---
LLM_TYPE=deepseek
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_INTENT_MODEL=deepseek-chat
DEEPSEEK_ANSWER_MODEL=deepseek-chat

# ZhipuAI (智谱)
ZHIPUAI_API_KEY=
ZHIPUAI_MODEL=glm-4-plus

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen:32b
